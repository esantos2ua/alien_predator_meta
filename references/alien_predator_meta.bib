  author = {O'Dea, Rose E. and Lagisz, Malgorzata and Jennions, Michael D. and Koricheva, Julia and Noble, Daniel W.A. and Parker, Timothy H. and Gurevitch, Jessica and Page, Matthew J. and Stewart, Gavin and Moher, David and Nakagawa, Shinichi},
